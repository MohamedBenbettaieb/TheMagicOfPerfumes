<Window x:Class="TheMagicOfPerfumes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TheMagicOfPerfumes.ViewModels"
        xmlns:views="clr-namespace:TheMagicOfPerfumes.Views"
        Title="The Magic of Perfumes"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- WPF uses these to know which View to render for each ViewModel -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
            <views:CategoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductViewModel}">
            <views:ProductView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SaleViewModel}">
            <views:SaleView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#1a1a2e">
            <TextBlock Text="✨ Magic of Perfumes"
                       Foreground="White" FontSize="14" FontWeight="Bold"
                       Margin="16,24,16,32" TextWrapping="Wrap"/>

            <Button Content="Dashboard"
                    Command="{Binding NavigateToDashboardCommand}"
                    Margin="8,4" Padding="12,10"/>
            <Button Content="Categories"
                    Command="{Binding NavigateToCategoriesCommand}"
                    Margin="8,4" Padding="12,10"/>
            <Button Content="Products"
                    Command="{Binding NavigateToProductsCommand}"
                    Margin="8,4" Padding="12,10"/>
            <Button Content="Customers"
                    Command="{Binding NavigateToCustomersCommand}"
                    Margin="8,4" Padding="12,10"/>
            <Button Content="New Sale"
                    Command="{Binding NavigateToSalesCommand}"
                    Margin="8,4" Padding="12,10"/>
        </StackPanel>

        <!-- Main content area — renders current ViewModel's View -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>