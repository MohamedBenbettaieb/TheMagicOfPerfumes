<UserControl x:Class="TheMagicOfPerfumes.Views.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="32">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Categories"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <!-- Form -->
        <Border Grid.Row="1"
                Background="#f9f9f9"
                BorderBrush="#e0e0e0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{Binding IsEditing,
                           Converter={StaticResource BoolToStringConverter},
                           ConverterParameter='Edit Category|Add New Category'}"
                           FontWeight="SemiBold" Margin="0,0,0,12"/>

                <TextBlock Text="Category Name" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0,0,0,8"
                           Visibility="{Binding ErrorMessage,
                                        Converter={StaticResource StringToVisibilityConverter}}"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding IsEditing,
                            Converter={StaticResource BoolToStringConverter},
                            ConverterParameter='Update|Add Category'}"
                            Command="{Binding SaveCommand}"
                            Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelEditCommand}"
                            Padding="16,8"
                            Visibility="{Binding IsEditing,
                                         Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Categories List -->
        <!-- Updated DataGrid without ID column -->
        <DataGrid Grid.Row="2"
          ItemsSource="{Binding Categories}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTemplateColumn Header="Actions" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"
                                Command="{Binding DataContext.EditCategoryCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="10,4" Margin="0,0,6,0"/>
                                <Button Content="Delete"
                                Command="{Binding DataContext.ShowDeleteConfirmationCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="10,4"
                                Background="Red" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Delete Confirmation Overlay -->
        <Grid Grid.RowSpan="3"
              Background="#80000000"
              Visibility="{Binding IsDeleteConfirmationVisible, 
                           Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Background="White"
                    Padding="20"
                    Width="300"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock Text="Confirm Delete"
                               FontSize="18" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding CategoryToDelete.Name, 
                                 StringFormat='Are you sure you want to delete &quot;{0}&quot;?'}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <Button Content="Yes"
                                Command="{Binding ConfirmDeleteCommand}"
                                Background="Red" 
                                Foreground="White"
                                Padding="20,8" 
                                Margin="0,0,10,0"/>

                        <Button Content="No"
                                Command="{Binding CancelDeleteCommand}"
                                Background="Gray" 
                                Foreground="White"
                                Padding="20,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>