<UserControl x:Class="TheMagicOfPerfumes.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="32">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Products"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <!-- Form -->
        <Border Grid.Row="1"
                Background="#f9f9f9"
                BorderBrush="#e0e0e0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- Form Title -->
                <TextBlock Text="{Binding FormTitle}"
                           FontWeight="SemiBold" 
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Name -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Product Name *" 
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"/>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                        <TextBlock Text="Category *" 
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding NewProductCategory}"
                                  DisplayMemberPath="Name"
                                  Padding="8,6"/>
                    </StackPanel>

                    <!-- Price -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Price *" 
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewProductPrice,
                                        UpdateSourceTrigger=LostFocus,
                                        Converter={StaticResource DecimalInputConverter},
                                        TargetNullValue=''}"
                                 Padding="8"/>
                    </StackPanel>


                    <!-- Description (full width) -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                        <TextBlock Text="Description" 
                                   Margin="0,0,0,4"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewProductDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8" 
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>

                <!-- Required Fields Hint -->
                <TextBlock Text="* Required fields"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="0,0,0,8"/>

                <!-- Success Message -->
                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="Green"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,8,0,0"
                           Visibility="{Binding SuccessMessage,
                            Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red" 
                           FontSize="12"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding SaveButtonText}"
                            Command="{Binding SaveCommand}"
                            Padding="16,8" 
                            Margin="0,0,8,0"
                            IsDefault="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#007acc"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#cccccc"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Cancel"
                            Command="{Binding CancelEditCommand}"
                            Padding="16,8"
                            IsCancel="True"
                            Background="#6c757d"
                            Foreground="White"
                            BorderThickness="0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter Section -->
        <Border Grid.Row="2"
        Background="#f5f5f5"
        BorderBrush="#e0e0e0"
        BorderThickness="1"
        CornerRadius="4"
        Padding="12"
        Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by Category:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedFilterCategory}"
                  DisplayMemberPath="Name"
                  Width="200"
                  Padding="8,4"/>
                <Button Content="Clear Filter"
                Command="{Binding ClearFilterCommand}"
                Padding="12,4"
                Margin="8,0,0,0"
                Background="#6c757d"
                Foreground="White"
                BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFilterCategory}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#cccccc"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="{Binding FilteredProducts.Count, StringFormat='  ({0} products)'}"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"
                   FontStyle="Italic"
                   Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Products DataGrid -->
        <DataGrid Grid.Row="3"
          ItemsSource="{Binding FilteredProducts}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          RowDetailsVisibilityMode="VisibleWhenSelected"
          AlternatingRowBackground="#f9f9f9"
          BorderBrush="#e0e0e0"
          BorderThickness="1">

            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Setter Property="MinHeight" Value="35"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                            Binding="{Binding Name}"
                            Width="2*"/>
                <DataGridTextColumn Header="Category"
                            Binding="{Binding Category.Name}"
                            Width="*"/>
                <DataGridTextColumn Header="Price"
                            Binding="{Binding Price, StringFormat={}{0:N2} DT}"
                            Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="5,0,10,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Actions" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Edit"
                                Command="{Binding DataContext.EditProductCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="10,4"
                                Margin="0,0,6,0"
                                Background="#28a745"
                                Foreground="White"
                                BorderThickness="0"/>
                                <Button Content="Delete"
                                Command="{Binding DataContext.DeleteProductCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="10,4"
                                Background="#dc3545"
                                Foreground="White"
                                BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#f5f5f5"
                    Padding="12"
                    BorderBrush="#e0e0e0"
                    BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="Description:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,0,0,4"/>
                            <TextBlock Margin="20,0,0,0"
                               Foreground="#333333"
                               TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Description}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                <Setter Property="Text" Value="No description provided."/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Text" Value="No description provided."/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </Grid>
</UserControl>